---
import CvListBlock from "./CvListBlock.astro";
import CvSubtitle from "./CvSubtitle.astro";

import type { CvData } from "@data/cv";

export interface Props {
  project_data: CvData["projects"][number];
}

const { project_data: data } = Astro.props;
---

<div class="project-card">
  <div class="proj-header">
    <CvSubtitle variant="medium">
      {data.name}
    </CvSubtitle>
    <div class="proj-badges">
      {
        data.badges.map((badge) => (
          <span class="badge badge-green">{badge}</span>
        ))
      }
    </div>
  </div>
  <div class="pills-row">
    {data.stack.map((tech) => <span class="pill">{tech}</span>)}
  </div>
  <CvListBlock>
    {data.bullets.map((bullet) => <li>{bullet}</li>)}
  </CvListBlock>
</div>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-bottom: 1px dotted #ddd;
  }
  .project-card:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .proj-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .proj-badges {
    display: flex;
    gap: 4px;
    flex-shrink: 0;
    padding-top: 2px;
  }

  .badge {
    font-family: "IBM Plex Mono", monospace;
    font-size: 9pt;
    font-weight: 700;
    padding: 1.5px 7px;
    border-radius: 20px;
    border: 1px solid;
    white-space: nowrap;
  }
  .badge-green {
    color: #15803d;
    background: #f0fdf4;
    border-color: #86efac;
  }
  .badge-gray {
    color: #555;
    background: #f5f5f5;
    border-color: #ddd;
  }

  .pills-row {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .pill {
    font-family: "IBM Plex Mono", monospace;
    font-size: 9pt;
    font-weight: 600;
    padding: 1.5px 7px;
    border-radius: 20px;
    border: 1px solid #bfdbfe;
    background: #eff6ff;
    color: #1a56db;
    white-space: nowrap;
  }
</style>
