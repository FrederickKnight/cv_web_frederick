---
type WeightsVariant = "small" | "medium" | "big";

export interface Props {
  variant: WeightsVariant;
}

const { variant } = Astro.props;

const weights = {
  small: "600",
  medium: "700",
  big: "700",
};
---

<div
  class:list={[
    "cv-subtitle",
    {
      "cv-subtitle--big": variant === "big",
      "cv-subtitle--medium": variant === "medium",
      "cv-subtitle--small": variant === "small",
    },
  ]}
>
  <slot />
</div>

<style define:vars={{ weight: weights[variant] }}>
  .cv-subtitle {
    font-weight: var(--weight);
    line-height: 1.3;
    color: #111;
  }

  .cv-subtitle--big {
    font-size: 13pt;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    border-bottom: 2px solid #111;
    margin-bottom: 2mm;

    grid-column: 1 / -1;
  }

  .cv-subtitle--medium {
    font-size: 12pt;
    color: #111;
  }

  .cv-subtitle--small {
    font-size: 10pt;
  }
</style>
