---
import CvListBlock from "./CvListBlock.astro";
import CvSubtitle from "./CvSubtitle.astro";

import type { CvData } from "@data/cv";

export interface Props {
  experience_data: CvData["experience"][number];
}

const { experience_data: data } = Astro.props;
---

<div>
  <div>
    <div class="flex-row space-between">
      <CvSubtitle variant="medium">
        {data.role}
      </CvSubtitle>
      <div>{data.date}</div>
    </div>
    <div>{data.company}</div>
  </div>
  <CvListBlock>
    {data.bullets.map((b) => <li>{b}</li>)}
  </CvListBlock>
</div>

<style>
  .flex-row {
    display: flex;
    flex-direction: row;
    align-items: center;
  }
  .space-between {
    justify-content: space-between;
  }
</style>
