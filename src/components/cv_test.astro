        </section>
      </div>
      <div class="cv-right">
        <section class="cv-section">
          <div class="cv-section-title">Habilidades</div>
          <div class="cv-skill-group">
            <div class="cv-skill-cat">Lenguajes</div>
            <div class="cv-tags">
              <span class="cv-tag cv-tag-primary">Python</span>
              <span class="cv-tag cv-tag-primary">JavaScript</span>
              <span class="cv-tag cv-tag-muted">Java</span>
            </div>
          </div>
          <div class="cv-skill-group">
            <div class="cv-skill-cat">Backend</div>
            <div class="cv-tags">
              <span class="cv-tag cv-tag-primary">Flask</span>
              <span class="cv-tag cv-tag-primary">FastAPI</span>
              <span class="cv-tag cv-tag-primary">SQLAlchemy</span>
