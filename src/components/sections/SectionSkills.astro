---
import CvSubtitle from "@components/CvSubtitle.astro";
import type { CvData } from "@data/cv";

export interface Props {
  data: CvData;
}

const { data } = Astro.props;
---

<section class="skills-section">
  <CvSubtitle variant="big">{data.sections.skills}</CvSubtitle>

  <div class="skills-grid">
    {
      data.skills.map((skill) => (
        <div class="skill-group">
          <span class="skill-label">{skill.label}:</span>

          <div class="skill-pills">
            {skill.values.map((value) => (
              <span class="pill">{value}</span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .skills-section {
    width: 100%;
    break-inside: avoid;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: start;
    gap: 6px 14px;
  }

  .skill-group {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 3px;
    break-inside: avoid;
  }

  .skill-label {
    color: #111;
    font-size: 9pt;
    font-weight: 700;
    line-height: 1.2;
  }

  .skill-pills {
    min-width: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 2px 3px;
  }

  .pill {
    display: inline-flex;
    align-items: center;

    padding: 0 5px;
    border: 1px solid #bfdbfe;
    border-radius: 999px;

    background: #eff6ff;
    color: #1a56db;

    font-size: 8pt;
    font-weight: 600;
    line-height: 1.45;
    white-space: nowrap;
  }
</style>
