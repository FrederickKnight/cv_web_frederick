---
import CvSubtitle from "@components/CvSubtitle.astro";
import type { CvData } from "@data/cv";

export interface Props {
  data: CvData;
}

const { data } = Astro.props;
---

<div class="skills-section">
  <CvSubtitle variant="big">{data.sections.skills}</CvSubtitle>

  <div class="skill-group">
    <span class="skill-label">{data.skill_sections.languages}:</span>
    <div class="skill-pills">
      <span class="pill">Python</span>
      <span class="pill">JavaScript</span>
      <span class="pill pill-gray">Java</span>
    </div>
  </div>

  <div class="skill-group">
    <span class="skill-label">Backend:</span>
    <div class="skill-pills">
      <span class="pill">Django</span>
      <span class="pill">Flask</span>
      <span class="pill">FastAPI</span>
      <span class="pill">SQLAlchemy</span>
    </div>
  </div>

  <div class="skill-group">
    <span class="skill-label">Frontend:</span>
    <div class="skill-pills">
      <span class="pill">React</span>
      <span class="pill">React Native</span>
      <span class="pill">TypeScript</span>
      <span class="pill">Astro</span>
      <span class="pill">HTML5</span>
      <span class="pill">CSS3</span>
    </div>
  </div>

  <div class="skill-group">
    <span class="skill-label">DevOps:</span>
    <div class="skill-pills">
      <span class="pill">APIs REST</span>
      <span class="pill">Docker</span>
      <span class="pill">AWS</span>
      <span class="pill">Git</span>
      <span class="pill">GitHub</span>
      <span class="pill pill-gray">CI/CD</span>
      <span class="pill pill-gray">Terraform</span>
    </div>
  </div>

  <div class="skill-group">
    <span class="skill-label">{data.skill_sections.database}:</span>
    <div class="skill-pills">
      <span class="pill">PostgreSQL</span>
      <span class="pill">SQLite</span>
    </div>
  </div>
</div>

<style>
  .skills-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 16px;
  }

  .skill-group {
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }

  .skill-label {
    font-size: 10t;
    font-weight: 700;
    color: #111;
    min-width: 84px;
    flex-shrink: 0;
    padding-top: 2px;
  }

  .skill-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .pill {
    display: inline-block;
    font-size: 8pt;
    font-weight: 600;
    padding: 1.5px 7px;
    border-radius: 20px;
    border: 1px solid #bfdbfe;
    background: #eff6ff;
    color: #1a56db;
    line-height: 1.5;
    white-space: nowrap;
  }

  .pill-gray {
    background: #f5f5f5;
    border-color: #ddd;
    color: #555;
  }
</style>
